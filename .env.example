# Bu faylı .env adı ilə kopyalayıb real dəyərləri doldur.
# .env faylı .gitignore-da olmalıdır və HEÇ VAXT commit edilməməlidir.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexora_academy
DB_USER=nexora_app
DB_PASSWORD=1234

# Base64-encoded HMAC-SHA secret, min. 256 bit (32 byte) decoded.
# Generate one with: openssl rand -base64 48
JWT_SECRET=asdghagkjasddjkasdfkasdkjadjkakjadsfjkadfbkvdaskbadskbhad2479324427g4327g24g72f37g932f973f29ghf32h9f239h23f9ug3f2u9f32gu9329gu3932f9329832f98g3f9g83f9g83f9g8f3g9f39g8f3hudskhsdfhklsfdhksdhasdgiuarog7wr8438yogf3w8yo3fwey8g3fweygo83wfeygo3fygo3wyg3ewygo83yg3ewyg3wy83yg8ygf3r8eyg83ryg3ryg3ry3oy
JWT_ISSUER=nexora-academy
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=2592000000

# Lokal SMTP (default-lar MailHog-un standart portuna uyğundur —
# bax docker-compose.yml/mailhog xidməti; UI: http://localhost:8025).
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@nexora-academy.local

# Reset-password / email-verify linkləri bu bazaya qoşulur (frontend tətbiqinin ünvanı).
FRONTEND_BASE_URL=http://localhost:3000
PASSWORD_RESET_EXPIRATION_MS=3600000
EMAIL_VERIFY_EXPIRATION_MS=86400000

# CRUD/error logları (bax logback-spring.xml) hansı qovluqda saxlanılsın.
LOG_DIR=logs
